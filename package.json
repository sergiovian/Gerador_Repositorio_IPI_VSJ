{
  "name": "louvor-inteligente",
  "version": "1.0.0",
  "description": "Sistema para organização de repertórios de louvor.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test test/*.test.js",
    "db:init": "node -e \"const x=require('./backend/database/database');x.databaseReady.then(()=>x.getDatabase().close()).catch(console.error)\"",
    "db:seed": "node -e \"const x=require('./backend/database/database');x.databaseReady.then(()=>x.getDatabase().close()).catch(console.error)\"",
    "db:import:ipi": "node backend/database/import-ipi-vila-sao-jose.js"
  },
  "keywords": ["louvor", "repertorio", "express", "sqlite"],
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
